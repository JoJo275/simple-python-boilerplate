{
    // ─────────────────────────────────────────────────────────────────
    // Folder-level Settings (.vscode/settings.json)
    // ─────────────────────────────────────────────────────────────────
    //
    // These are project-functional settings that ensure the toolchain
    // works correctly. They load for EVERY open method:
    //   • File > Open Folder  (most common, Codespaces, devcontainers)
    //   • File > Open Workspace from File  (.code-workspace)
    //
    // The .code-workspace file contains ONLY extension recommendations
    // and cosmetic preferences (indentRainbow). It deliberately avoids
    // duplicating settings here — this file is the single source of truth.
    //
    // TODO (template users): Review all sections below and adjust to
    //   match your project's tooling (formatter, linter, test runner).
    //   Delete sections for tools you don't use.
    // ─────────────────────────────────────────────────────────────────

    // ── Python Environment ──────────────────────────────────
    // TODO (template users): Update the interpreter path for your platform:
    //   Windows: .venv/Scripts/python
    //   macOS/Linux: .venv/bin/python
    //   Hatch: run `hatch env find` to get the path, then append
    //          /Scripts/python (Windows) or /bin/python (macOS/Linux)
    // If using Hatch as environment manager, change envManager to
    //   "ms-python.python:hatch" (requires Python Environments extension
    //   with Hatch support).
    //
    // NOTE: If VS Code shows "Python interpreter not found" or picks the
    // wrong interpreter, select it manually:
    //   1. Ctrl+Shift+P → "Python: Select Interpreter"
    //   2. Choose "Enter interpreter path..." and paste the Hatch env path
    //      from `hatch env find` (e.g. on Windows:
    //      C:\Users\<you>\AppData\Local\hatch\env\virtual\...\Scripts\python.exe)
    //   VS Code remembers the selection per-workspace — you only need to
    //   do this once.
    // "python.defaultInterpreterPath": ".venv/Scripts/python",
    "python-envs.pythonProjects": [
        {
            "path": ".",
            "packageManager": "ms-python.python:pip"
        }
    ],

    // ── Schema Trust ────────────────────────────────────────
    // Allow VS Code to fetch JSON schemas for validation
    // (fixes the "untrusted location" warning on .code-workspace
    // and markdownlint config files).
    "json.schemaDownload.enable": true,

    // ── Python Analysis (Pylance) ───────────────────────────
    // "standard" catches more issues than "basic" and aligns closer
    // to the strict mypy config in pyproject.toml.
    // TODO (template users): Set to "basic" if "standard" is too noisy
    //   for your codebase, or "strict" to match mypy exactly.
    "python.analysis.typeCheckingMode": "standard",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.analysis.inlayHints.pytestParameters": true,

    // ── Testing ─────────────────────────────────────────────
    // Auto-discover pytest tests so the Test Explorer sidebar works.
    // TODO (template users): Change pytestArgs if your tests live
    //   somewhere other than tests/.
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "tests"
    ],

    // ── Terminal ─────────────────────────────────────────────
    // Auto-activate the venv when opening a new terminal.
    "python.terminal.activateEnvironment": true,

    // ── Python Formatting ───────────────────────────────────
    // Ruff as formatter + auto-fix on save for Python files.
    // These must be per-language overrides (not global) so they
    // don't affect YAML, Markdown, JSON, etc.
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        }
    },

    // ── Ruff ────────────────────────────────────────────────
    // In-editor linting behaviour. Reads rules from pyproject.toml.
    // NOTE: "ruff.lint.run" was removed — it is a legacy ruff-lsp
    // setting that triggers a deprecation warning with the new
    // native Ruff server. Linting runs automatically on every
    // keystroke by default.
    "ruff.fixAll": true,
    "ruff.organizeImports": true,

    // ── Markdown ────────────────────────────────────────────
    // markdownlint reads rules from .markdownlint-cli2.jsonc.
    // Don't auto-format on save — Prettier reformatting can conflict
    // with markdownlint rules and manual table alignment.
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": false,
        "editor.wordWrap": "on"
    },

    // ── YAML ────────────────────────────────────────────────
    "[yaml]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // ── JSONC ───────────────────────────────────────────────
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // ── Editor ──────────────────────────────────────────────
    // Rulers at 88 (ruff line-length) and 120 (readable limit).
    "editor.rulers": [88, 120],
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.renderWhitespace": "trailing",
    "editor.stickyScroll.enabled": true,

    // ── Files ───────────────────────────────────────────────
    // Trim trailing whitespace and ensure final newline — matches
    // the pre-commit hooks (trailing-whitespace, end-of-file-fixer).
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,

    // ── Files Explorer ──────────────────────────────────────
    // Hide generated/cache dirs in the explorer sidebar.
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.egg-info": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true,
        "**/site": true
    },

    // ── Search ──────────────────────────────────────────────
    // Exclude noisy generated/cache directories from search results.
    "search.exclude": {
        "**/__pycache__": true,
        "**/*.egg-info": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true,
        "**/node_modules": true,
        "**/site": true,
        "**/.venv": true
    },

    // ── Git ─────────────────────────────────────────────────
    // Auto-fetch and prune stale remote-tracking branches.
    // NOTE: "git.pruneOnFetch" only applies to VS Code's auto-fetch.
    // For terminal `git fetch` to also prune, set the git config:
    //   git config --global fetch.prune true
    // The git_doctor.py script runs `git fetch --all --prune`
    // explicitly on each run regardless of this setting.
    "git.pruneOnFetch": true,
    "git.autofetch": true,
    "git.fetchOnPull": true,
    // Confirm before force-pushing to prevent accidental history rewrites.
    "git.confirmForcePush": true,
    // Confirm before syncing (push + pull) to avoid surprises.
    "git.confirmSync": true,
    // Show inline blame annotations (who last changed each line).
    "git.blame.editorDecoration.enabled": true,
    // Auto-stash before pull-rebase so dirty worktrees don't block pulls.
    // Mirrors the git config: rebase.autostash = true
    "git.autoStash": true,
    // Use rebase instead of merge when pulling (linear history).
    // Mirrors the git config: pull.rebase = true
    "git.rebaseWhenSync": true,
    // Follow tags when pushing (matches push.followTags git config).
    "git.followTagsWhenSync": true,
    // Show the full commit message in the source control input on amend.
    "git.inputValidationSubjectLength": 50,
    "git.inputValidationLength": 72,

    // ── Task Runner ─────────────────────────────────────────
    // Auto-detect Taskfile.yml tasks in the task runner panel.
    "task.autoDetect": "on",

    // ── Error Lens ──────────────────────────────────────────
    // Show errors/warnings inline. Exclude cSpell hints to reduce
    // noise (typos pre-commit hook catches those at commit time).
    "errorLens.enabledDiagnosticLevels": ["error", "warning"],
    "errorLens.excludeBySource": ["cSpell"],
    "errorLens.delay": 500,

    // ── Code Spell Checker ──────────────────────────────────
    // Demote spell-check to hints so they don't clutter the
    // Problems panel alongside real errors.
    "cSpell.diagnosticLevel": "Hint",

    // ── Indent Rainbow ──────────────────────────────────────
    // Each indent level gets a distinct background colour so
    // Python's significant whitespace is immediately visible.
    // Increase A (e.g. 0.15 → 0.25) for stronger contrast.
    "indentRainbow.colors": [
        "rgba(255, 99, 71, 0.15)",
        "rgba(255, 165, 0, 0.15)",
        "rgba(255, 255, 0, 0.15)",
        "rgba(50, 205, 50, 0.15)",
        "rgba(0, 191, 255, 0.15)",
        "rgba(138, 43, 226, 0.15)",
        "rgba(255, 20, 147, 0.15)"
    ],
    "indentRainbow.indicatorStyle": "classic",
    "indentRainbow.colorOnWhiteSpaceOnly": true
}
