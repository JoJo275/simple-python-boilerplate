# =============================================================================
# .gitattributes — Line endings, diff drivers, language stats, archive export
# =============================================================================
# Docs: https://git-scm.com/docs/gitattributes
#
# TODO (template users): Add or remove binary/text overrides as your project
#   grows (e.g., proto files, generated code, vendored assets).
# =============================================================================

# ==============
# Line Endings
# ==============

# Normalize all text files to LF in the repo, convert to native on checkout
* text=auto eol=lf

# Force LF for shell scripts even on Windows checkouts
*.sh text eol=lf
*.bash text eol=lf

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ==============
# Diff Drivers
# ==============

# Use language-aware diffs for better hunk headers
*.py diff=python
*.md diff=markdown

# ==============
# Binary Files
# ==============

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg text

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Archives
*.zip binary
*.tar.gz binary
*.gz binary

# Database files
*.sqlite3 binary
*.db binary

# ==============
# Lock Files
# ==============

# Treat lock files as generated (no manual diff review needed)
*.lock linguist-generated=true
requirements.txt linguist-generated=true
requirements-dev.txt linguist-generated=true

# ==============
# SQL Language
# ==============

# Ensure SQL is counted
*.sql linguist-language=SQL
*.sql linguist-detectable=true
*.sql linguist-vendored=false

# ==============
# HTML Language
# ==============

# Ensure HTML is counted
*.html linguist-language=HTML
*.html linguist-detectable=true
*.html linguist-vendored=false

# ==============
# CSS Language
# ==============

# Ensure CSS is counted
*.css linguist-language=CSS
*.css linguist-detectable=true
*.css linguist-vendored=false

# ==============
# Language Stats — Exclude Generated / Non-Source
# ==============

# MkDocs build output (generated site)
site/** linguist-generated=true

# Egg-info metadata
*.egg-info/** linguist-generated=true

# CHANGELOG is auto-generated by release-please
CHANGELOG.md linguist-generated=true

# ==============
# Export Ignore — Exclude from `git archive` / GitHub tarballs
# ==============

# Development-only files that end users don't need
.editorconfig export-ignore
.gitattributes export-ignore
.gitignore export-ignore
.gitmessage.txt export-ignore
.github/ export-ignore
.pre-commit-config.yaml export-ignore
.markdownlint-cli2.jsonc export-ignore
.dockerignore export-ignore
.containerignore export-ignore
.repo-doctor.toml export-ignore
_typos.toml export-ignore
codecov.yml export-ignore
Containerfile export-ignore
docker-compose.yml export-ignore
Taskfile.yml export-ignore
release-please-config.json export-ignore
.release-please-manifest.json export-ignore
mkdocs.yml export-ignore
docs/ export-ignore
tests/ export-ignore
scripts/ export-ignore
experiments/ export-ignore
db/ export-ignore
labels/ export-ignore
mkdocs-hooks/ export-ignore
repo_doctor.d/ export-ignore
site/ export-ignore
var/ export-ignore
